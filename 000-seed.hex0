48 89 C7                                  ; mov rdi, rax
;; @0x671: call parse_decimal_code (rel32 = 0x5FD - 0x676 = -121)
E8 87 FF FF FF
48 8B 7D 00                               ; mov rdi, [rbp]   ; rdi = n (or 0)
48 83 C5 08                               ; add rbp, 8
48 8B 04 25 00 30 41 00                   ; mov rax, [STATE]
48 85 C0                                  ; test rax, rax
75 01                                     ; jnz .Lcompile
