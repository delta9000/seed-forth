48 8B 75 20                               ; mov rsi, [rbp+32]  ; b
48 8B 7D 28                               ; mov rdi, [rbp+40]  ; a
0F 05                                     ; syscall  (rcx,r11 clobbered; unused)
48 83 C5 30                               ; add rbp, 48        ; pop 6 args
48 89 C7                                  ; mov rdi, rax       ; new TOS = result
C3

