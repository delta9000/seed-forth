89 50 FC                                  ; mov [rax-4], edx
48 89 38                                  ; mov [rax], rdi   ; inline 8-byte cell
48 83 C0 08                               ; add rax, 8
48 89 04 25 10 30 41 00                   ; mov [HERE], rax  ; HERE += 13
48 8B 7D 00                               ; mov rdi, [rbp]
48 83 C5 08                               ; add rbp, 8
